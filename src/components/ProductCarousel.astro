---
import ProductCard from './ProductCard.astro';
import ArrowRight from './ArrowRight.astro';
const { carouselTitle } = Astro.props;
---

<div class="m-4">
	{ carouselTitle && 
		<div class="flex justify-between items-center mb-4">
			<h2 class="text-3xl">{carouselTitle}</h2>
			<a href="#"><ArrowRight /></a>
		</div> 
	}
	<div class="flex flex-row gap-x-4 overflow-scroll">
		<ProductCard />
		<ProductCard />
		<ProductCard />
		<ProductCard />
	</div>
</div>

