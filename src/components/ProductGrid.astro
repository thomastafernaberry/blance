---
import ProductCard from './ProductCard.astro';
import Product from '../services/Product.ts';

interface Props {
	category?: string;
}

const { category  } = Astro.props as Props;
// ?
const sorting = (await Astro.session?.get('sorting')) || '';

const params = Astro.url.searchParams;
const searchValue = params.get('q') || '';

// Get products
const productService = await Product.init();
let productsObj = await productService.searchByName(searchValue, sorting);
if (category) {
	productsObj = await productService.searchByCategory(category, sorting);
}

let [title, subtitle] = '';
// Set title
if (searchValue) {
	title = `Buscando "${searchValue}"`;
} else if (category) {
	title = `Categoría ${category}`;
}
// Set subtitle
if (productsObj.data.length === 0) {
	subtitle = 'No hay productos que coincidan con tu búsqueda.';
}
---

<div class="grid gap-4">
	{ title && <h1 class="text-2xl text-center capitalize mt-4">{title}</h1> }	
	{ subtitle && <h4 class="text-sm text-gray-300 text-center">{subtitle}</h4> }
	{ (searchValue || category) && <a href="/store" class="underline block text-center mb-2">Reiniciar la búsqueda</a> }
</div>

<div id="products-container">
		{ productsObj.data.values().map( p => <a href=`/store/${p.name}`> <ProductCard name={p.name} price={p.price}/> </a>) }
</div> 


<style>
	#products-container {
		display: grid;
		padding: 1rem;
	}

	#products-container {
		grid-template-columns: 1fr;
	}

	#products-container.double {
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}
</style>
