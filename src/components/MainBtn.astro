---
interface Props {
	text: string;
	id?: string;
	href?: string;
}

const { text, id, href } = Astro.props as Props;
---
<a id={id} href={href} class="bg-black text-white tracking-wide w-full h-20 rounded-3xl shadow-md cursor-pointer grid place-content-center bg-black text-white py-8 rounded-3xl cursor-pointer mt-6 shadow-md outline-2 hover:bg-white hover:text-black hover:outline-2 hover:scale-98 duration-300 ease-in-out">{text}</a>

