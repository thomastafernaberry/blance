---
import Product from '../services/Product.ts';
import Color from '../components/Color.astro';
import MainBtn from '../components/MainBtn.astro';

interface Props {
	name: string;
	price: number;
	description: string;
	composition: string;
}

const { 
	name = '',
	price = 0,
	description = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur',
	composition = '',
} = Astro.props as Props;
---

<main class="grid">
	<img class="rounded-4xl p-4 pt-2 place-self-center" src="/src/images/product-big.jpg" />
	<div class="px-4 pt-2">
		<h1 class="text-3xl/10 my-2 font-regular text-dark capitalize">{name}<h1>
		<h2 class="text-xl pb-6">${price}</h2>
		<Color hexColor="#000" />
		<MainBtn text="Anadir al carrito" />
	</div>
	<div class="bg-white-100 mx-4 mt-24 rounded-4xl" >
		<div class="flex justify-between bg-white-200 rounded-t-4xl border-gray-200 h-12 border-b-1">
			<button class="bg-dark text-white rounded-tl-4xl py-2 px-6 w-full">Descripción</button>
			<button class="bg-white-200 rounded-tr-4xl py-2 px-6 w-full">Composición</button>
		</div>
		<p class="text-sm/7 text-gray-300 font-light px-6 py-4">{description}</p>
	</div>
</main>
