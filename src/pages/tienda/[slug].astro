---
import { actions } from 'astro:actions';
import Product from '../../services/Product.ts';
import BaseLayout from '../../components/BaseLayout.astro';
import ProductDetail from '../../components/ProductDetail.astro';

export async function getStaticPaths() {
	const productService = await Product.init();
	const slugs = await productService.getAllSlugs();	
	return slugs.map( slug => ( { params: { slug: slug } } ) );
}

const { slug } = Astro.params;

const { data, error } = await Astro.callAction(actions.getProducts, { 
	productSlug: slug,
});

if (error) {
	return;	
}

const productData = data.data[0];
---

<BaseLayout currentPage="detail">
	<ProductDetail productData={productData} />
</BaseLayout
