---
export const prerender = false;

import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import ProductGrid from '../components/ProductGrid.astro';
import StoreHeader from '../components/StoreHeader.astro';
import { strapi } from '@strapi/client';

const client = strapi({ 
	baseURL: 'http://localhost:1337/api', 
	auth: '6031cbfee033dd02a388254bd028e2cd2af74f2924bf60a4a142822b4357c95e1323d6a105a1220a09a191855b4316f84def1fda7430b37e0add2e04885489834b8b592094f5cf9d304363367b03db4882c64da5907aa5f4c3914e3c29b537c9ba1905b77409732a3bdc08bb7879268df87e82d819c8ef3ad95fa0d1778f15a9'
});

let allProducts = '';
let product = '';
try {
	allProducts = await client.collection('products');
	product = await allProducts.find({name:'Lenceria'});
	product = product.data[0];
} catch (e) {
	allProducts = e;
}

const searchParams = (new URL(Astro.request.url)).searchParams;
const view = searchParams.get('v');
---

<html>
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta charset="UTF-8">
</head>
<body>
	<Navbar currentPage="store" />
	<StoreHeader />
	<ProductGrid viewMode={view} />
</body>
</html>
