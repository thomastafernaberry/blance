---
import { actions } from 'astro:actions';
import Product from '../../services/Product.ts';
import BaseLayout from '../../components/BaseLayout.astro';
import ProductDetail from '../../components/ProductDetail.astro';

export async function getStaticPaths() {
	const productService = await Product.init();
	const productNames = await productService.getAllNames();	
	return productNames.map( n => ( { params: { product: n }}));
}

const { product } = Astro.params;

const { data, error } = await Astro.callAction(actions.getProducts, { productName: product });

const p = data?.data?.[0];
---

<BaseLayout currentPage="detail">
	<ProductDetail name={p.name} price={p.price} />
</BaseLayout
