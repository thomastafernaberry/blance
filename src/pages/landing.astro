<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Advanced Landing Page</title>
  <link href="/src/styles/global.css" rel="stylesheet">
</head>
<body class="bg-sky-100 text-gray-800">
  <header class="bg-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold">My Advanced Landing Page</h1>
        <nav>
          <ul class="flex space-x-4">
            <li><a href="#" class="hover:underline">Home</a></li>
            <li><a href="#" class="hover:underline">Features</a></li>
            <li><a href="#" class="hover:underline">Pricing</a></li>
            <li><a href="#" class="hover:underline">Contact</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Section -->
    <section class="text-center py-12 bg-gradient-to-r from-sky-100 to-cyan-100">
      <h2 class="text-4xl font-bold mb-4 text-gray-800">Welcome to Our Service</h2>
      <p class="text-xl mb-8">Discover the best features and benefits of our product.</p>
      <a href="#" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-full">
        Get Started
      </a>
    </section>

    <!-- Video Section -->
    <section class="mt-12">
      <div class="relative h-64 bg-gray-200 rounded-lg overflow-hidden">
        <iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/dQw4w9WgXcQ" frameborder="0" allowfullscreen></iframe>
      </div>
      <div class="text-center py-6">
        <h3 class="text-3xl font-bold mb-4">Watch Our Introduction Video</h3>
        <p class="text-gray-600">Learn more about our product and how it can benefit you.</p>
      </div>
    </section>

    <!-- Features Section -->
    <section class="mt-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="text-2xl font-bold mb-2">Feature One</h3>
          <p>Learn more about our first amazing feature.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="text-2xl font-bold mb-2">Feature Two</h3>
          <p>Discover the benefits of our second feature.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="text-2xl font-bold mb-2">Feature Three</h3>
          <p>Explore the advantages of our third feature.</p>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="mt-12 bg-gray-50">
      <div class="text-center py-12">
        <h3 class="text-3xl font-bold mb-4">About Us</h3>
        <p class="text-gray-600 mb-8">We are a team of passionate developers dedicated to creating innovative solutions that enhance your productivity and creativity.</p>
        <div class="flex justify-center space-x-8">
          <div class="max-w-xs">
            <img src="/path/to/your/image1.jpg" alt="Team Member 1" class="w-32 h-32 rounded-full object-cover">
            <p class="text-sm font-semibold text-gray-500 mt-2">- Jane Doe</p>
          </div>
          <div class="max-w-xs">
            <img src="/path/to/your/image2.jpg" alt="Team Member 2" class="w-32 h-32 rounded-full object-cover">
            <p class="text-sm font-semibold text-gray-500 mt-2">- John Smith</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="mt-12">
      <div class="text-center py-12 bg-gradient-to-b from-cyan-100 to-sky-100">
        <h3 class="text-3xl font-bold mb-4">What Our Customers Say</h3>
        <div class="flex justify-center space-x-8">
          <div class="max-w-xs">
            <p class="text-gray-600">"This product has changed the way I work. Highly recommend!"</p>
            <p class="text-sm font-semibold text-gray-500">- Jane Doe</p>
          </div>
          <div class="max-w-xs">
            <p class="text-gray-600">"Incredible value for the price. A must-have for everyone."</p>
            <p class="text-sm font-semibold text-gray-500">- John Smith</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section class="mt-12 bg-white shadow-md">
      <div class="text-center py-12">
        <h3 class="text-3xl font-bold mb-4">Get in Touch</h3>
        <form class="max-w-md mx-auto">
          <div class="flex flex-col space-y-4">
            <input type="text" placeholder="Your Name" class="w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input type="email" placeholder="Your Email" class="w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            <textarea placeholder="Your Message" rows="4" class="w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
            <button type="submit" class="w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-md">
              Send Message
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- Call to Action Section -->
    <section class="mt-12 bg-gradient-to-b from-cyan-100 to-sky-100">
      <div class="text-center py-12">
        <h3 class="text-3xl font-bold mb-4 text-gray-800">Ready to Get Started?</h3>
        <a href="#" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full">
          Sign Up Now
        </a>
      </div>
    </section>
  </main>

  <footer class="bg-white shadow-md mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-gray-600">© 2023 My Advanced Landing Page. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
